    "@codemirror/view": "^6.43.6",
    "@git-diff-view/core": "^0.1.7",
    "@git-diff-view/solid": "^0.1.7",
    "@lezer/common": "^1.5.2",
    "@lezer/highlight": "^1.2.3",
    "@replit/codemirror-css-color-picker": "^6.3.0",
