{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TUICommander (Pablo)",
  "identifier": "com.pablo.tuicommander",
  "build": {
    "beforeBuildCommand": "pnpm exec vite build && pnpm build:sidecar"
  },
  "bundle": {
    "createUpdaterArtifacts": false
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "http://127.0.0.1:0/disabled"
      ]
    }
  }
}
